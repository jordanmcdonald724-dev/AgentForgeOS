# AgentForgeOS — Environment Configuration Template
# Copy this file to config/.env and fill in your values.
# Never commit config/.env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Database ────────────────────────────────────────────────────────────────
# MongoDB connection URI. Leave blank to run without persistence.
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=agentforgeos

# ── LLM Provider ────────────────────────────────────────────────────────────
# Set PROVIDER_LLM to one of: ollama, openai
PROVIDER_LLM=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# OpenAI (cloud — optional)
OPENAI_API_KEY=

# ── Image Provider ───────────────────────────────────────────────────────────
# Set PROVIDER_IMAGE to one of: comfyui, fal
PROVIDER_IMAGE=comfyui

# ComfyUI (local)
COMFYUI_BASE_URL=http://localhost:8188

# Fal (cloud — optional)
FAL_API_KEY=

# ── TTS Provider ─────────────────────────────────────────────────────────────
# Set PROVIDER_TTS to one of: piper
PROVIDER_TTS=piper

# Piper (local)
PIPER_MODEL_PATH=

# ── Bridge ───────────────────────────────────────────────────────────────────
# Root directory that the bridge is allowed to read/write.
# Agents cannot access paths outside this root.
BRIDGE_ROOT=./workspace

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
