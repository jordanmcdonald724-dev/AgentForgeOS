{
  "version": 1,
  "enabled_engines": [
    "local"
  ],
  "api_keys": {
    "fal": "",
    "openai": "",
    "anthropic": ""
  },
  "cost_controls": {
    "max_cost_usd_per_day": null,
    "max_cost_usd_per_request": null,
    "max_log_entries": 5000
  },
  "task_routing": {
    "planning": {
      "engine": "fal",
      "model": "fal-ai/llama3.1-8b-instruct",
      "fallback": [
        { "engine": "openai", "model": "gpt-4o-mini" },
        { "engine": "local", "model": "llama3" }
      ]
    },
    "coding": {
      "engine": "fal",
      "model": "deepseek-ai/deepseek-coder-6.7b-instruct",
      "fallback": [
        { "engine": "openai", "model": "gpt-4o-mini" },
        { "engine": "local", "model": "llama3" }
      ]
    },
    "ui_design": {
      "engine": "openai",
      "model": "gpt-4o-mini",
      "fallback": [
        { "engine": "fal", "model": "fal-ai/llama3.1-8b-instruct" },
        { "engine": "local", "model": "llama3" }
      ]
    },
    "debugging": {
      "engine": "fal",
      "model": "deepseek-ai/deepseek-coder-6.7b-instruct",
      "fallback": [
        { "engine": "openai", "model": "gpt-4o-mini" },
        { "engine": "local", "model": "llama3" }
      ]
    },
    "research": {
      "engine": "fal",
      "model": "fal-ai/llama3.1-8b-instruct",
      "fallback": [
        { "engine": "openai", "model": "gpt-4o-mini" }
      ]
    },
    "summarize": {
      "engine": "openai",
      "model": "gpt-4o-mini",
      "fallback": [
        { "engine": "local", "model": "llama3" }
      ]
    },
    "conversation": {
      "engine": "local",
      "model": "llama3",
      "fallback": [
        { "engine": "openai", "model": "gpt-4o-mini" }
      ]
    }
  },
  "engines": {
    "local": {
      "provider": "ollama",
      "base_url": "http://localhost:11434",
      "timeout_sec": 120
    },
    "fal": {
      "base_url": "https://fal.run",
      "timeout_sec": 120,
      "retries": 2
    },
    "openai": {
      "base_url": "https://api.openai.com/v1",
      "timeout_sec": 60,
      "retries": 2
    },
    "anthropic": {
      "base_url": "https://api.anthropic.com",
      "timeout_sec": 60,
      "retries": 2
    }
  }
}

